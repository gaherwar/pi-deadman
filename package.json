{
  "name": "pi-breaker",
  "version": "1.0.0",
  "description": "Prevents macOS freezes during pi sessions. Auto-kills runaway processes when memory runs out.",
  "type": "module",
  "keywords": [
    "pi-package",
    "memory",
    "macos",
    "watchdog",
    "breaker",
    "freeze",
    "crash",
    "oom",
    "swap",
    "ram",
    "memory-pressure",
    "kill",
    "process-manager",
    "system-health"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "os": [
    "darwin"
  ],
  "author": "gaherwar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaherwar/pi-breaker.git"
  },
  "homepage": "https://github.com/gaherwar/pi-breaker#readme",
  "bugs": {
    "url": "https://github.com/gaherwar/pi-breaker/issues"
  },
  "license": "MIT"
}
